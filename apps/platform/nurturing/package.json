{
  "name": "@platform/nurturing",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "npx tsx node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/sensible": "^5.0.0",
    "@ortho/interpolator": "file:../../../packages/@ortho/interpolator",
    "@ortho/openapi": "file:../../../packages/@ortho/openapi",
    "@sinclair/typebox": "^0.34.0",
    "bullmq": "^5.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.0.0",
    "knex": "^3.0.0",
    "pg": "^8.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
