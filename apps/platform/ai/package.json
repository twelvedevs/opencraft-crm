{
  "name": "@platform/ai",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "migrate": "npx tsx node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@arizeai/openinference-instrumentation-anthropic": "^0.1.0",
    "@fastify/sensible": "^6.0.0",
    "@opentelemetry/instrumentation": "^0.57.0",
    "@ortho/logger": "file:../../../packages/@ortho/logger",
    "@sinclair/typebox": "^0.34.0",
    "fastify": "^5.0.0",
    "lru-cache": "^11.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
