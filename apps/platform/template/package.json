{
  "name": "@platform/template",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "npx tsx node_modules/knex/bin/cli.js migrate:latest --knexfile migrations/knexfile.ts"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.0",
    "@sinclair/typebox": "^0.34.0",
    "fastify": "^5.0.0",
    "jose": "^5.0.0",
    "knex": "^3.0.0",
    "lru-cache": "^11.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
