    "ioredis": "latest",
    "knex": "^3.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "tsx": "^4.0.0",
