    "@ortho/event-bus": "file:../../../packages/@ortho/event-bus",
    "@ortho/fastify-logger": "file:../../../packages/@ortho/fastify-logger",
    "@ortho/logger": "file:../../../packages/@ortho/logger",
    "@ortho/openapi": "file:../../../packages/@ortho/openapi",
    "@ortho/types": "file:../../../packages/@ortho/types",
    "@sinclair/typebox": "^0.34.0",
    "fastify": "^5.8.4",
    "knex": "^3.0.0",
    "libphonenumber-js": "^1.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "fast-jwt": "^6.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
